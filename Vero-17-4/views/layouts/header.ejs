<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="<%= typeof description !== 'undefined' ? description : 'Vero Admin Dashboard' %>"
    />
    <title><%= typeof title !== 'undefined' ? title : 'Vero Admin' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
    <style>
      .app-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 40px;
        background: var(--surface-glass);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--surface-glass-border);
        position: sticky;
        top: 0;
        z-index: 100;
      }
      .app-nav-brand {
        font-size: 1.25rem;
        font-weight: 800;
        letter-spacing: 2px;
        background: linear-gradient(135deg, var(--gray-50), var(--gray-400));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-decoration: none;
      }
      .app-nav-actions {
        display: flex;
        align-items: center;
        gap: 24px;
      }
      .nav-admin-info {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        color: var(--gray-300);
      }
      .nav-logout-btn {
        background: none;
        border: 1.5px solid var(--error);
        color: var(--error);
        padding: 6px 16px;
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all var(--transition-base);
      }
      .nav-logout-btn:hover {
        background: var(--error);
        color: white;
      }
    </style>
  </head>
  <body>
    <% if (typeof admin !== 'undefined' && admin) { %>
      <nav class="app-nav">
        <a href="/dashboard" class="app-nav-brand">Vero</a>
        <div class="app-nav-actions">
          <div class="nav-admin-info">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
              <circle cx="12" cy="7" r="4" />
            </svg>
            <span><%= admin.username %></span>
          </div>
          <form action="/admin/logout" method="POST" style="margin: 0;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="nav-logout-btn">خروج</button>
          </form>
        </div>
      </nav>
    <% } %>
